@model IEnumerable<Book>
@{
	Layout = "_AdminLayout";
    ViewData["Title"] = "Books";
}

<h2>Books</h2>


<a asp-action="AddBook" asp-controller="Book" class="btn btn-primary">Add</a>

@if (Model?.Count() > 0)
{
	<table class="table table-striped my-2">
		<tr>
			<th>IMage</th>
			<th>Book</th>
			<th>Author</th>
			<th>Genre</th>
			<th>Price</th>
			<th>Stock</th>
			<th>Action</th>
		</tr>
		@foreach (var book in Model)
		{
			<tr>
				<td>
					@if (String.IsNullOrWhiteSpace(book.Image))
					{
						<img src="~/images/No_Image_Available.jpg" style="width:80px; height:100px" alt="Book Image"/>
					}
					else
					{
						<img src="~/images/@book.Image" style="width:80px; height:100px" alt="Book Image" />
					}
				</td>
				<td>@book.Name</td>
				<td>@book.AuthorName</td>
				<td>@book.Genre?.Name</td>
				<td>@book.Price</td>
				<td>@book.Stock?.Quantity</td>
				<td>
					<a asp-action="UpdateBook" asp-controller="Book" asp-route-id="@book.Id" class="btn btn-success">Edit</a>
					<a asp-action="Delete" asp-controller="Book" asp-route-id="@book.Id" class="btn btn-danger"
					onclick="return confirm('Are you sure?')">Delete</a>
				</td>
			</tr>
		}
	</table>
}
else
{
	<h3>No records</h3>
}
