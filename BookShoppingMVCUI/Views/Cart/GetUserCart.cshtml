@model ShoppingCart
@{
    ViewData["Title"] = "My Cart";
}

<div style="width:90%; margin:auto;">
    @if (Model != null && Model.CartDetails != null && Model.CartDetails.Count>0)
    {
    <h5 class="mt-3">My Cart</h5>
        <table class="table table-hover">
            <tr>
                <th>#</th>
                <th>Book</th>
                <th>Image</th>
                <th>Genre</th>
                <th>Unit Price</th>
                <th>Total Price</th>
                <th>Actions</th>
            </tr>
            <tbody class="table-group-divider">
                @{
                    int index = 1;
                }
                @foreach(var item in Model.CartDetails)
                {
                    <tr>
                        <td>@index</td>
                        <td>@item.Book.Name</td>
                        <td>
                            @if (string.IsNullOrEmpty(item.Book.Image))
                            {
                                <img src="/images/No_Image_Available.jpg" style="width:80px; height:100px"/>
                            }
                            else
                            {
                                <img src="/images/@item.Book.Image" style="width:80px; height:100px" />
                            }
                        </td>
                        <td>@item.Book.Genre.Name</td>
                        <td>@item.Book.Price X @item.Quantity</td>
                        <td>@(item.Book.Price * @item.Quantity)</td>
                        <td>
                            <a class="btn btn-info" href="/Cart/AddItem?bookId=@item.BookId&&redirect=1">+</a>
                            <a class="btn btn-info" href="/Cart/removeItem?bookId=@item.BookId">-</a>
                        </td>
                    </tr>
                    index++;
                }
            </tbody>
        </table>
        <div class="my-2 d-flex gap-3">
            <h5>Total Price : </h5>
            <span class="fw-bold">@(Model.CartDetails.Select(item => item.Book.Price * item.Quantity).Sum())</span>
        </div>
        <div class="my-2">
            <a class="btn btn-primary" href="/Cart/CheckOut">CheckOut</a>
        </div>
    }
    else
    {
        <h3>Cart is empty</h3>
    }
</div>