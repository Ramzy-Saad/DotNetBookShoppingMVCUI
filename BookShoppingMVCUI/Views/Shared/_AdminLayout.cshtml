@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css"
          rel="stylesheet"
          integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC"
          crossorigin="anonymous" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <link rel="stylesheet" href="~/css/admin-layout.css" asp-append-version="true" />

</head>
<body>
    <div class="main-contaier">
        <div class="sidenav">
            <a asp-controller="Home" asp-action="Index"
               class="navigation-link @(controller == "Home" && action == "Index" ? "active" : "")">
                <i class="bi bi-house-door"></i> Home
            </a>

            <a asp-controller="AdminOperation" asp-action="AllOrders"
               class="navigation-link @(controller == "AdminOperation" && action == "AllOrders" ? "active" : "")">
                <i class="bi bi-receipt"></i> Orders
            </a>

            <a asp-controller="Stock" asp-action="Index"
               class="navigation-link @(controller == "Stock" ? "active" : "")">
                <i class="bi bi-archive"></i> Stock
            </a>

            <a asp-controller="Genre" asp-action="Index"
               class="navigation-link @(controller == "Genre" ? "active" : "")">
                <i class="bi bi-collection"></i> Genre
            </a>

            <a asp-controller="Book" asp-action="Index"
               class="navigation-link @(controller == "Book" ? "active" : "")">
                <i class="bi bi-book"></i> Books
            </a>

            <a asp-controller="Reports" asp-action="TopFiveSellingBooks"
               class="navigation-link @(controller == "Reports" ? "active" : "")">
                <i class="bi bi-bar-chart"></i> Top Selling Items
            </a>
        </div>
        <div class="right-panel">
            <nav class="nav-bar">
                <div class="nav-heading">Welcome @User.Identity?.Name</div>
                <div class="nav-actions">
                    <a href="/Identity/Account/Manage/Index" class="navigation-link"><i class="bi bi-gear"></i> Manage account</a>
                    <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                        <button type="submit" class="navigation-link">
                            <i class="bi bi-box-arrow-left"></i> Logout
                        </button>
                    </form>
                </div>
            </nav>
            <div class="content">
                @RenderBody()
            </div>
        </div>
    </div>
</body>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-MrcW6ZMFYlzcLA8Nl+NtUVF0sA7MsXsP1UyJoMp4YLEuNSfAP+JcXn/tWtIaxVXM"
        crossorigin="anonymous"></script>
</html>