@model IEnumerable<Order>
@{
    ViewData["Title"] = "My orders";
}

<div style="width:90%; margin:auto;">
    <a href="/Identity/Account/Manage" class="btn btn-primary my-2">Back</a>
    @if (Model != null && Model.Count()>0)
    {
        <h5 class="mt-3">My Orders</h5>
        <table class="table table-hover">
            <thead>
            <th>#</th>
            <th>OrderDate</th>
            <th>OrderStatus</th>
            </thead>
            <tbody class="table-group-divider">
                @{
                    int index = 1;
                }
                @foreach (var order in Model)
                {
                    <tr>
                        <td>@index</td>
                        <td>@order.CreateDate.ToString("dd-MM-yyyy")</td>
                        <td>@order.OrderStatus.Name</td>
                        @if(order.OrderDetail!=null && order.OrderDetail.Count() > 0)
                        {
                            <span>Order Details</span>
                        }
                    </tr>
                    index++;
                }
            </tbody>
        </table>
        <div class="my-2 d-flex gap-3">
            <h5>Total Price : </h5>
            @* <span class="fw-bold">@(Model.Select(order => order.OrderDetail * item.Quantity).Sum())</span> *@
        </div>
    }
    else
    {
        <h3>No orders exist</h3>
    }
</div>