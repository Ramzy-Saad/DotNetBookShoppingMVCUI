@model IEnumerable<Order>
@{
    ViewData["Title"] = "My orders";
}

<div style="width:100%;">
    <a href="/Identity/Account/Manage" class="btn btn-primary my-2">Back</a>
    @if (Model != null && Model.Count()>0)
    {
        <h5 class="mt-3">My Orders</h5>
        <table class="table table-hover">
            <tr>
                <th>#</th>
                <th>OrderDate</th>
                <th>OrderStatus</th>
            </tr>
            <tbody class="table-group-divider">
                @{
                    int index = 1;
                }
                @foreach (var order in Model)
                {
                    <tr>
                        <td>@index</td>
                        <td>@order.CreateDate.ToString("dd-MM-yyyy")</td>
                        <td>@order.OrderStatus.Name</td>
                    </tr>
                    @if(order.OrderDetail!=null && order.OrderDetail.Count() > 0){
                        <tr>
                            <td colspan="2">
                            <table class="table table-hover">
                                <tr>
                                    <th>#</th>
                                    <th>Book</th>
                                    <th>Image</th>
                                    <th>Genre</th>
                                    <th>Unit Price</th>
                                    <th>Total Price</th>
                                </tr>
                                <thead>
                                <tbody class="table-group-divider">
                                    @{
                                        int orderdetailIndex = 1;
                                    }
                                    @foreach (var item in order.OrderDetail)
                                    {
                                        <tr>
                                            <td>@orderdetailIndex</td>
                                            <td>@item.Book.Name</td>
                                            <td>
                                                @if (string.IsNullOrEmpty(item.Book.Image))
                                                {
                                                    <img src="/images/No_Image_Available.jpg" style="width:80px; height:100px" />
                                                }
                                                else
                                                {
                                                    <img src="/images/@item.Book.Image" style="width:80px; height:100px" />
                                                }
                                            </td>
                                            <td>@item.Book.Genre.Name</td>
                                            <td>@item.UnitPrice X @item.Quantity</td>
                                            <td>@(item.UnitPrice* @item.Quantity)</td>
                                        </tr>
                                        orderdetailIndex++;
                                    }
                                        <tr class="fw-bold fs-6">
                                            <td colspan="5">Total Price : </td>
                                            <td>
                                                @(order.OrderDetail.Select(item => item.UnitPrice * item.Quantity).Sum())
                                            </td>
                                        </tr>
                                </tbody>
                            </table>

                        </td>

                    </tr>
                    }
                    index++;
                }
            </tbody>
        </table>
        <div class="my-2 d-flex gap-3">
            <h5>Total Price : </h5>
            @* <span class="fw-bold">@(Model.Select(order => order.OrderDetail * item.Quantity).Sum())</span> *@
        </div>
    }
    else
    {
        <h3>No orders exist</h3>
    }
</div>